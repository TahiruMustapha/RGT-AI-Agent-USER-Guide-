# TEMPLATE: Full .reviewerc Example
# ────────────────────────────────────
# Shows all major features in one file.
# Uncomment the sections you want to use.
#
# USAGE: Save as .reviewerc at your repo root. Remove or comment out
#        anything you don't need.

version: 1

# ── Commands ──────────────────────────────────────────────────────────────────
# Define reusable review commands. Trigger manually with !<id> in a PR comment,
# or add to review.run to run automatically on every PR.

commands:
  - id: security
    title: "Security scan"
    prompt: |
      Review for auth bypass, hardcoded secrets, unsafe deserialization,
      SQL injection, XSS, and missing input validation.
      Flag HIGH severity issues immediately.
    tools:
      allow: [filesystem, git.read, github.pr.read, github.pr.feedback]
    limits:
      maxFindings: 15
    output:
      severityFloor: medium

  - id: perf
    title: "Performance review"
    prompt: |
      Look for N+1 database queries, unnecessary allocations, missing indexes,
      synchronous operations that should be async, and expensive operations
      inside loops.
    tools:
      allow: [filesystem, git.read, github.pr.read, github.pr.feedback]

  - id: tests
    title: "Test coverage check"
    prompt: |
      Check if new functions, endpoints, and business logic changes have
      corresponding tests. Flag any logic added without test coverage.
    tools:
      allow: [filesystem, git.read, github.pr.read, github.pr.feedback]

  - id: docs-drift
    title: "Docs drift check"
    prompt: |
      Compare README.md and docs/ against code changes from the last 24 hours.
      Update any outdated sections. When done: git add, git commit, push_pr.
    tools:
      allow: [filesystem, git.history, repo.write, github.pr.manage]


# ── Review (PR-time) ──────────────────────────────────────────────────────────

review:
  defaults:
    provider: google
    model: gemini-3-pro-preview
    reasoning: medium
    contextFile: .github/copilot-context.md   # team conventions file

  # Commands that run automatically on every PR (in addition to the standard review)
  run: [security]
  # run: [security, perf]   # uncomment to run multiple commands automatically

  # PR filters
  keywordFilters:
    skipKeywords: [WIP, "do-not-review", draft]

  baseBranchFilters:
    include: [main, "release/*"]    # only review PRs targeting these branches

  # headBranchFilters:
  #   exclude: ["chore/*", "docs/*"]  # uncomment to skip these source branches

  labelFilters:
    exclude: [wip, skip-review]

  # Experimental features
  # experimental:
  #   prExplainer: true          # post a PR guide + per-file explainer comments
  #   hashlinesEnabled: true     # improves suggestion accuracy on weaker models


# ── Schedule (cron maintenance) ────────────────────────────────────────────────
# Requires separate scheduled workflow files. Job names must match workflow job names.

schedule:
  enabled: true
  runs:
    nightly-docs: [docs-drift]
    # weekly-security: [security-audit]   # uncomment when you add that command

  conditions:
    paths:
      include: ["README.md", "docs/**", "src/**"]

  writeScope:
    include: ["README.md", "docs/**"]   # bot can only edit these paths


# ── Tool allowlist ─────────────────────────────────────────────────────────────
# Global list of tool categories available to all commands.
# Commands can further restrict via tools.allow but cannot expand beyond this list.

tools:
  allowlist:
    - filesystem
    - git.read
    - git.history
    - github.pr.read
    - github.pr.feedback
    - github.pr.manage
    - repo.write
    - agent.subagent
