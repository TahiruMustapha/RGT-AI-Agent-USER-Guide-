# TEMPLATE: Basic .reviewerc
# ────────────────────────────
# Minimal configuration. Sets default model and enables the on-demand
# !explain command (built-in, no extra setup needed).
#
# USAGE: Save as .reviewerc at your repo root.

version: 1

review:
  defaults:
    provider: google
    model: gemini-3-pro-preview
    reasoning: medium
