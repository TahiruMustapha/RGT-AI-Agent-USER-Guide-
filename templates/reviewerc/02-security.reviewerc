# TEMPLATE: Security-focused .reviewerc
# ────────────────────────────────────────
# Runs a dedicated security scan on every PR in addition to the standard review.
# Can also be triggered manually with !security in a PR comment.
#
# USAGE: Save as .reviewerc at your repo root.

version: 1

commands:
  - id: security
    title: "Security scan"
    prompt: |
      Review for security vulnerabilities only. Focus on:
      - Auth bypass and privilege escalation
      - Hardcoded secrets, tokens, or credentials
      - SQL injection, XSS, command injection
      - Unsafe deserialization
      - Missing input validation on user-supplied data
      - Sensitive data exposed in logs or responses

      Flag anything HIGH severity immediately.
      Skip style, formatting, and non-security observations.
    tools:
      allow: [filesystem, git.read, github.pr.read, github.pr.feedback]
    limits:
      maxFindings: 15
    output:
      severityFloor: medium    # only report medium and above

review:
  defaults:
    provider: google
    model: gemini-3-pro-preview
    reasoning: high            # security reviews benefit from deeper reasoning
  run: [security]              # runs automatically on every PR
