# TEMPLATE: Nightly Docs + Weekly Security .reviewerc
# ──────────────────────────────────────────────────────
# Defines two scheduled maintenance commands:
#   - docs-drift: runs nightly, checks if README/docs match recent code
#   - security-audit: runs weekly, sweeps for new vulnerabilities
#
# USAGE:
#   1. Save as .reviewerc at your repo root
#   2. Add nightly-docs.yml workflow (templates/workflows/05-nightly-docs.yml)
#   3. Add weekly-security.yml workflow (templates/workflows/06-weekly-security.yml)
#
# NOTE: Job names in schedule.runs must exactly match job names in workflow files.

version: 1

commands:
  - id: docs-drift
    title: "Docs drift check"
    prompt: |
      Compare README.md and the docs/ directory against code changes from
      the last 24 hours. Use git history to identify what changed.

      Update any documentation that no longer matches the code:
      - Changed function signatures or behaviour
      - New or removed configuration options
      - Updated API endpoints or response shapes

      When finished making changes:
        git add <changed files>
        git commit -m "docs: sync with recent code changes"
        push_pr

      If nothing is out of date, do nothing.
    tools:
      allow: [filesystem, git.history, repo.write, github.pr.manage]

  - id: security-audit
    title: "Weekly security audit"
    prompt: |
      Review code changes from the last 7 days for security vulnerabilities.
      Focus on:
      - New auth or permission logic
      - New API endpoints and their input validation
      - New database queries
      - Newly introduced dependencies
      - Hardcoded secrets or credentials

      Report findings as a summary. If fixes are straightforward and safe,
      apply them, commit, and open a PR. Otherwise just report.
    tools:
      allow: [filesystem, git.history, github.pr.manage, repo.write]

schedule:
  enabled: true
  runs:
    nightly-docs: [docs-drift]          # job name must match workflow job name
    weekly-security: [security-audit]   # job name must match workflow job name

  # Only run docs-drift if these paths had recent changes
  conditions:
    paths:
      include: ["README.md", "docs/**", "src/**"]

  # Limit which files the bot is allowed to edit
  writeScope:
    include: ["README.md", "docs/**"]   # only docs can be auto-edited

tools:
  allowlist:
    - filesystem
    - git.read
    - git.history
    - github.pr.read
    - github.pr.feedback
    - github.pr.manage
    - repo.write
